apiVersion: apps/v1
kind: Deployment
metadata: 
  name: sachin-dep
spec:
  replicas: 3
  selector:
    matchLabels:  
      app: dev 
  template:
    metadata: 
      name: temp-my
      labels: 
        app: dev 
    spec: 
      containers:
      - name: sachin-app
        image: rathodsr/moviehub:v1
        ports:
        - containerPort: 80
---

apiVersion: v1
kind: Service
metadata:
  name: my-svc
spec:
  selector:
    app: dev
  ports:
  - protocol: "TCP"
    port: 80
    targetPort: 80
  type: NodePort
